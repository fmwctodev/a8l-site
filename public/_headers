/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  X-Robots-Tag: all

# More-specific overrides for private pages. Netlify applies the most
# specific matching path when the same header appears on multiple rules.
/thank-you
  X-Robots-Tag: noindex, nofollow

/application-received
  X-Robots-Tag: noindex, nofollow

/aiads-vsl
  X-Robots-Tag: noindex, nofollow

# Long-cache static assets served from /public. Next.js handles its own
# /_next/static/* immutable caching automatically via @netlify/plugin-nextjs;
# these rules cover the legacy /public assets (logos, downloads, fonts).
/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

/llms-full.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400
