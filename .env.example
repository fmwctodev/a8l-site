# a8l-site environment variables.
# Copy to .env.local for local dev. Configure the same keys in Netlify
# for staging/prod deployments.

# ─────────────────────────────────────────────────────────────────────
# Public form intake — a8l-os Supabase Edge Function backing /get-in-touch
# and /join-us. The marketing site POSTs to {URL}/functions/v1/form-submit/{slug}
# with the anon key. The Edge Function uses its own service-role key
# internally for the actual writes; these public keys only get the request
# past the Supabase gateway.
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# ─────────────────────────────────────────────────────────────────────
# GA4 / GTM (already configured separately in Next.js metadata; included
# here for completeness if conversionEvents needs explicit override).
# ─────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────────────────────────────
# Capability statement modal — SendGrid (existing, unchanged).
# Lives in netlify/functions/capabilities-webhook.js, server-side only.
# ─────────────────────────────────────────────────────────────────────
# SENDGRID_API_KEY=SG....
# SENDGRID_FROM_EMAIL=info@autom8ionlab.com
